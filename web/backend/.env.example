# DeepRare Web Backend Configuration
# Copy this file to .env and fill in the values

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Default API Keys (optional - users can also provide per-request)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# Google Custom Search (for web search)
GOOGLE_CSE_ID=
GOOGLE_CSE_API_KEY=

# Bing Search
BING_SUBSCRIPTION_KEY=

# Exomiser (for gene-aware diagnosis)
EXOMISER_JAR_PATH=
EXOMISER_DATA_PATH=

# DeepRare data paths
ORPHANET_KNOWLEDGE_PATH=
DISEASE_EMBEDDINGS_PATH=
SIMILAR_CASES_PATH=
HPO_CONCEPT2ID_PATH=
HPO_EMBEDDINGS_PATH=
ORPHA_CONCEPT2ID_PATH=
ORPHA2OMIM_PATH=
EXOMISER_SAVE_PATH=
